# Esta plantilla no crea el tunel ni registros DNS. Primero iniciar el backend
# localmente en la VM; despues crear el tunel y el hostname publico en Cloudflare.
# Backend expuesto solo en localhost; Cloudflare Tunnel publicara la API.
APP_PORT=8080
SPRING_PROFILES_ACTIVE=production

# Fecha operativa de Colombia. Mantener ambas variables para que el sistema
# operativo y la JVM calculen ventas, precios y promociones con la misma fecha.
TZ=America/Bogota
JAVA_TOOL_OPTIONS=-Duser.timezone=America/Bogota

# Supabase PostgreSQL: usar la cadena de Session pooler mostrada en Connect.
# Separar host, puerto, usuario y contrasena; no pegar la URL JDBC completa.
DB_HOST=aws-<region>.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.<project-ref>
DB_PASSWORD=
DB_SSLMODE=require

# Seguridad de sesiones
JWT_SECRET=
JWT_EXPIRATION_MINUTES=60

# Origenes que Vercel publicara cuando se asocien estos dominios. No incluir
# rutas ni barra final. Declararlos aqui no crea registros DNS en Cloudflare.
CORS_ALLOWED_ORIGINS=https://kontora-pos.store,https://www.kontora-pos.store

# Supabase Storage. La clave se mantiene solo en la VM.
SUPABASE_STORAGE_BUCKET=kontoraimagenes
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SECRET_KEY=

# Solo para el primer arranque contra una base sin usuarios.
BOOTSTRAP_MANAGER_ENABLED=true
BOOTSTRAP_MANAGER_USERNAME=gerenteLocal
BOOTSTRAP_MANAGER_FULL_NAME=Gerente Local
BOOTSTRAP_MANAGER_PASSWORD=
