APP_PORT=8080
SPRING_PROFILES_ACTIVE=local

# PostgreSQL local dentro de Docker Compose
POSTGRES_PORT=5432
POSTGRES_DB=kontora_pos
POSTGRES_USER=kontora_pos
POSTGRES_PASSWORD=kontora_pos_local_password

# Datasource del backend cuando corra en Docker Compose local
DB_HOST=postgres
DB_PORT=5432
DB_NAME=kontora_pos
DB_USER=kontora_pos
DB_PASSWORD=kontora_pos_local_password
DB_SSLMODE=disable

# JWT
JWT_SECRET=
JWT_EXPIRATION_MINUTES=60

# CORS local para frontend Vite
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Provisiona el primer gerente solo cuando la tabla usuarios esta vacia.
# En la VM, activar y definir una contrasena exclusiva antes del primer arranque.
BOOTSTRAP_MANAGER_ENABLED=false
BOOTSTRAP_MANAGER_USERNAME=gerenteLocal
BOOTSTRAP_MANAGER_FULL_NAME=Gerente Local
BOOTSTRAP_MANAGER_PASSWORD=

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=
