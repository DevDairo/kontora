# Backend
APP_PORT=8080
SPRING_PROFILES_ACTIVE=local

# PostgreSQL local o Supabase PostgreSQL / Session Pooler
# Para Supabase usar DB_SSLMODE=require.
# Para PostgreSQL local usar DB_SSLMODE=disable.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kontora_pos
DB_USER=kontora_pos
DB_PASSWORD=kontora_pos_local_password
DB_SSLMODE=disable

# PostgreSQL local para Docker Compose
POSTGRES_PORT=5432
POSTGRES_DB=kontora_pos
POSTGRES_USER=kontora_pos
POSTGRES_PASSWORD=kontora_pos_local_password

# JWT
JWT_SECRET=
JWT_EXPIRATION_MINUTES=60

# CORS local para frontend Vite
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=

# Frontend
VITE_API_URL=http://localhost:8080/api
